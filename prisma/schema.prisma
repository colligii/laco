// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique() @db.VarChar(50)
  type         UserType      @default(User)
  password     String?       @db.VarChar(255)
  firstName    String?       @db.VarChar(50)
  lastName     String?       @db.VarChar(50)
  provider     Provider      @default(Local)
  avatarId     String?       @unique
  avatar       File?         @relation(fields: [avatarId], references: [id])
  stories      Story[]
  story_viewed StoryViewed[] @relation()

  @@map("user")
  storyReactions StoryReaction[]
  postComments PostComments[]
  postReactions PostReaction[]
  posts Post[]
  chats Chat[]
}

model File {
  id               String  @id @default(uuid())
  path             String
  user             User?
  type             FileType
  vertical_event   Event[] @relation("VerticalEventFile")
  horizontal_event Event[] @relation("HorizontalEventFile")
  stories          Story[]

  @@map("file")
  posts Post[]
}

model Event {
  id               String   @id @default(uuid())
  name             String   @db.VarChar(50)
  start_date       DateTime
  end_date         DateTime
  vertical_file_id String
  vertical_file    File     @relation("VerticalEventFile", fields: [vertical_file_id], references: [id])

  horizontal_file_id String
  horizontal_file    File    @relation("HorizontalEventFile", fields: [horizontal_file_id], references: [id])
  stories            Story[]

  @@map("event")
  posts Post[]
  chats Chat[]
}

model Story {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  file_id String
  file    File   @relation(fields: [file_id], references: [id])

  event_id String
  event    Event  @relation(fields: [event_id], references: [id])

  story_viewed StoryViewed[] @relation()

  @@map("story")
  storyReactions StoryReaction[]
}

model StoryViewed {
  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  story_id String
  story    Story  @relation(fields: [story_id], references: [id])

  @@id([user_id, story_id])
  @@map("story_viewed")
}

model StoryReaction {
  story_id String
  story    Story  @relation(fields: [story_id], references: [id])

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  reaction Reaction

  @@id([story_id, user_id])

  @@map("story_reaction")
}


model Post {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  file_id String
  file    File   @relation(fields: [file_id], references: [id])

  event_id String
  event    Event  @relation(fields: [event_id], references: [id])

  @@map("post")
  postReactions PostReaction[]
  postComments PostComments[]
}

model PostReaction {
  post_id String
  post  Post  @relation(fields: [post_id], references: [id])

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  reaction Reaction

  @@id([post_id, user_id])

  @@map("post_reaction")
}


model PostComments {
  id  String  @id() @default(uuid())
  
  post_id String
  post  Post  @relation(fields: [post_id], references: [id])

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  comment String  @db.VarChar(255)

  created_at DateTime @default(now())

  @@map("post_comment")
}

model Chat {

  id  String  @id() @default(uuid())
  message String  @db.VarChar(255)
  
  created_at DateTime @default(now())

  user_id String
  user  User  @relation(fields: [user_id], references: [id])

  event_id  String
  event Event @relation(fields: [event_id], references: [id])

  @@map("chat")
}


enum Reaction {
  Like
  Smile
  Clap
  Heart

  @@map("reaction")
}

enum FileType {
  Video
  Photo

  @@map("file_type")
}


enum Provider {
  Local
  Google
  Apple

  @@map("provider")
}

enum UserType {
  Admin
  User
}
